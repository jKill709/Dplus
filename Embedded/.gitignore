# =========================
# Ignore everything
# =========================

*

# =========================
# Allow directories
# =========================

!*/

# Allow src directory

!src/

# =========================

# Allow ONLY C++ source files in src

# =========================

!src/*.cpp
!src/*.h
!src/*.hpp
!src/**/*.cpp
!src/**/*.h
!src/**/*.hpp

# =========================

# Keep gitignore itself

# =========================

!.gitignore

